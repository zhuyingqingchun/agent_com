+    def _infer_task_candidates(self, instruction: str, app_name: str, task_type: str) -> List[str]:
+        candidates = [task_type]
+        if app_name in {"淘宝", "京东", "拼多多", "盒马"}:
+            candidates.append("shopping")
+        if app_name in {"抖音", "哔哩哔哩", "爱奇艺", "腾讯视频", "芒果TV", "快手", "优酷视频"}:
+            candidates.append("video")
+        if app_name in {"百度地图", "高德地图"}:
+            candidates.append("map")
+        if app_name in {"美团", "大众点评", "饿了么", "携程旅行", "去哪儿旅行"}:
+            candidates.append("food")
+            candidates.append("hotel")
+        if app_name in {"铁路12306", "滴滴出行"}:
+            candidates.append("travel")
+        if "支付" in instruction or "服务" in instruction:
+            candidates.append("pay")
+        dedup = []
+        for item in candidates:
+            if item not in dedup:
+                dedup.append(item)
+        return dedup[:4]
+
