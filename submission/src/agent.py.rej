+    def _is_interrupt_page(self) -> bool:
+        page_type = str(self._state.get("page_type", "")).lower()
+        interrupt_type = str(self._state.get("last_interrupt_type", "")).lower()
+        return page_type in self.INTERRUPT_TYPES or interrupt_type in self.INTERRUPT_TYPES
+
+    def _interrupt_handler(self, input_data: AgentInput) -> Tuple[str, Dict[str, Any]]:
+        interrupt_type = str(self._state.get("last_interrupt_type", "")).lower()
+        page_type = str(self._state.get("page_type", "")).lower()
+        current = interrupt_type or page_type
+        self._state["phase"] = "handle_interrupt"
+        self._state["milestone"] = f"resolve_{current or 'interrupt'}"
+        self._state["interrupt_count"] = int(self._state.get("interrupt_count", 0)) + 1
+
+        if current in {"permission", "dialog", "system_dialog", "update"}:
+            self._append_note("检测到权限/系统弹窗，优先处理右下或中右确认按钮。")
+            return ACTION_CLICK, {"point": [760, 720]}
+
+        if current in {"login"}:
+            self._append_note("检测到登录打断，优先关闭登录浮层或返回主流程。")
+            return ACTION_CLICK, {"point": [900, 120]}
+
+        if current in {"popup", "ad", "unknown_popup"}:
+            self._append_note("检测到弹窗/广告，优先尝试右上关闭或中心关闭。")
+            # 优先右上关闭，再失败可靠 page_stuck 触发二次恢复
+            return ACTION_CLICK, {"point": [920, 110]}
+
+        return ACTION_CLICK, {"point": [920, 110]}
 
