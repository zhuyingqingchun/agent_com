+    def _advance_phase(self, action: str, params: Dict[str, Any]):
+        phase = self._state.get("phase", "launch_app")
+        page_type = self._state.get("page_type", "unknown")
+        interrupt = self._is_interrupt_page()
+
+        if interrupt:
+            self._state["phase"] = "handle_interrupt"
+            return
+
+        if phase == "handle_interrupt":
+            if action == ACTION_CLICK:
+                self._state["phase"] = "reach_search"
+                self._state["milestone"] = "recover_main_flow"
+                self._state["last_interrupt_type"] = ""
+            return
+
+        if action == ACTION_OPEN:
+            self._state["phase"] = "reach_search"
+            self._state["milestone"] = "find_search_or_service_entry"
+            return
+
+        if phase == "launch_app":
+            self._state["phase"] = "reach_search"
+            self._state["milestone"] = "find_search_or_service_entry"
+            return
+
+        if phase == "reach_search":
+            if action == ACTION_CLICK:
+                self._state["phase"] = "fill_query"
+                self._state["milestone"] = "input_core_query"
+            elif action == ACTION_TYPE:
+                self._state["phase"] = "submit_query"
+                self._state["milestone"] = "submit_query"
+            return
+
+        if phase == "fill_query":
+            if action == ACTION_TYPE:
+                self._state["phase"] = "submit_query"
+                self._state["milestone"] = "submit_query"
+            return
+
+        if phase == "submit_query":
+            if action in {ACTION_CLICK, ACTION_SCROLL}:
+                self._state["phase"] = "browse_results"
+                self._state["milestone"] = "choose_best_candidate"
+            return
+
+        if phase == "browse_results":
+            if action == ACTION_CLICK:
+                self._state["phase"] = "enter_detail"
+                self._state["milestone"] = "open_candidate_detail"
+            return
+
+        if phase == "enter_detail":
+            if action in {ACTION_CLICK, ACTION_SCROLL}:
+                self._state["phase"] = "verify_goal"
+                self._state["milestone"] = "verify_goal_page"
+            return
+
+        if phase == "verify_goal" and action == ACTION_COMPLETE:
+            self._state["phase"] = "finish"
+            self._state["milestone"] = "done"
+
+        if page_type in {"detail"} and phase not in {"verify_goal", "finish"}:
+            self._state["phase"] = "verify_goal"
+            self._state["milestone"] = "verify_goal_page"
 
