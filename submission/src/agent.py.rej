+    def _refine_click_point(
+        self,
+        point: List[int],
+        candidate_region: str,
+        crop_point: Any,
+    ) -> List[int]:
+        candidate_region = candidate_region.upper().strip() if candidate_region else ""
+        if candidate_region not in self.REGION_BBOXES:
+            return point
+
+        x1, y1, x2, y2 = self.REGION_BBOXES[candidate_region]
+
+        if isinstance(crop_point, list) and len(crop_point) >= 2:
+            local = self._clamp_point(crop_point[0], crop_point[1])
+            rx = int(round(x1 + (x2 - x1) * local[0] / 1000.0))
+            ry = int(round(y1 + (y2 - y1) * local[1] / 1000.0))
+            refined = self._clamp_point(rx, ry)
+            self._state["last_candidate_region"] = candidate_region
+            return refined
+
+        px, py = point
+        inside = x1 <= px <= x2 and y1 <= py <= y2
+        if not inside or point == [500, 500]:
+            cx = int(round((x1 + x2) / 2))
+            cy = int(round((y1 + y2) / 2))
+            refined = self._clamp_point(cx, cy)
+            self._state["last_candidate_region"] = candidate_region
+            return refined
+
+        self._state["last_candidate_region"] = candidate_region
+        return point
+
