+    def _format_playbook_hits(self, hits: List[Dict[str, Any]]) -> str:
+        if not hits:
+            return "无"
+        lines = []
+        for item in hits[:3]:
+            lines.append(
+                f"- app={item.get('app_name')} task={item.get('task_type')} path={item.get('phases')} "
+                f"successful_regions={item.get('regions')} tips={item.get('tips')}"
+            )
+        return "\n".join(lines)
